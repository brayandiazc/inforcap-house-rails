# ==============================================================================
# Variables de entorno — InforcapHouse
# ==============================================================================
# Copia este archivo a `.env` y completa los valores para tu entorno.
#   cp .env.example .env
#
# NUNCA subas tu archivo `.env` con valores reales al repositorio.
# Ver SECURITY.md y docs/conventions/secrets.md.
#
# Nota: en desarrollo, Rails funciona sin `.env` usando config/database.yml.
# Estas variables son útiles sobre todo para staging/producción (p. ej. Heroku).
# ==============================================================================

# ── Entorno ───────────────────────────────────────────────────────────────
# Entorno de Rails: development | test | production
RAILS_ENV=development
# Puerto en el que escucha Puma
PORT=3000
# Máximo de threads por proceso
RAILS_MAX_THREADS=5

# ── Base de datos ─────────────────────────────────────────────────────────
# Cadena de conexión PostgreSQL (usada en producción / Heroku)
DATABASE_URL=postgres://usuario:password@localhost:5432/inforcap_house_development

# ── Secretos ──────────────────────────────────────────────────────────────
# Clave maestra de Rails para descifrar credentials (config/master.key).
# En local vive en config/master.key (NO se commitea); en el servidor va aquí.
RAILS_MASTER_KEY=
# Alternativamente, base secreta para firmar cookies/sesiones
SECRET_KEY_BASE=

# ── Correo (Action Mailer, opcional) ──────────────────────────────────────
# SMTP para envío de correos (recuperación de contraseña de Devise)
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_USER_NAME=
SMTP_PASSWORD=

# ── Logging ───────────────────────────────────────────────────────────────
# Nivel de log: debug | info | warn | error
RAILS_LOG_LEVEL=info
